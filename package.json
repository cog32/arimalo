{
  "name": "arimalo-covid",
  "version": "0.1.0",
  "private": true,
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^4.1.5",
    "appium": "^3.0.0",
    "eslint": "^10.2.1",
    "jsdom": "^28.1.0",
    "marked": "^17.0.4",
    "selenium-webdriver": "^4.34.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite --port 1420 --strictPort",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "parse": "cargo run --manifest-path src-tauri/Cargo.toml --bin ledger-parse --",
    "test:bdd": "npm run test:bdd:parser",
    "test:bdd:parser": "cargo test --manifest-path src-tauri/Cargo.toml --test bdd",
    "test:bdd:ui": "cucumber-js",
    "test:bdd:dry": "cucumber-js --dry-run",
    "e2e": "node scripts/run_tauri_webdriver_e2e.mjs",
    "e2e:mac": "E2E_BACKEND=appium-mac2 cucumber-js --tags @appium",
    "e2e:wd": "E2E_BACKEND=tauri-wd cucumber-js --tags \"not @wip and not @appium\"",
    "record:demos": "node scripts/record_demos.mjs",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "apexcharts": "^5.15.0",
    "morphdom": "^2.7.8"
  }
}
